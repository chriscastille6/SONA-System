[Unit]
Description=HSIRB Gunicorn
After=network.target postgresql.service

[Service]
User=ccastille
Group=ccastille
WorkingDirectory=/home/ccastille/hsirb-system
Environment=PATH=/home/ccastille/hsirb-system/venv/bin
ExecStart=/home/ccastille/hsirb-system/venv/bin/gunicorn --workers 3 --bind 127.0.0.1:8001 --timeout 120 config.wsgi:application
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
