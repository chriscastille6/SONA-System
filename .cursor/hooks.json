{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": ".cursor/hooks/block_pii_prompt.py",
        "timeout": 8000
      }
    ],
    "beforeReadFile": [
      {
        "command": ".cursor/hooks/block_sensitive_file_read.py",
        "timeout": 5000,
        "failClosed": true
      }
    ]
  }
}
