# Copy to config/mcp/.env and fill in secrets.
# Used by scripts/mcp-start.sh and scripts/mcp-bootstrap.sh

# MindsDB (defaults match docker-compose.mcp.yml)
MINDSDB_HOST=127.0.0.1
MINDSDB_PORT=47335
MINDSDB_HTTP_PORT=47334
MINDSDB_DATABASE=mindsdb
MINDSDB_USER=mindsdb
MINDSDB_PASS=

# PRAMS PostgreSQL (app database)
# Use host.docker.internal when MindsDB runs in Docker and PRAMS runs on the host.
PRAMS_POSTGRES_HOST=host.docker.internal
PRAMS_POSTGRES_PORT=5432
PRAMS_POSTGRES_DATABASE=recruitment_db
PRAMS_POSTGRES_USER=postgres
PRAMS_POSTGRES_PASSWORD=postgres

# GitLab (institutional) — optional; leave GITLAB_API_KEY empty to skip
GITLAB_URL=https://gitlab.nicholls.edu
GITLAB_REPOSITORY=chriscastille/prams
GITLAB_API_KEY=

# Future sources (optional — bootstrap skips when unset)
# GMAIL_USERNAME=
# GMAIL_PASSWORD=
# SLACK_TOKEN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=
